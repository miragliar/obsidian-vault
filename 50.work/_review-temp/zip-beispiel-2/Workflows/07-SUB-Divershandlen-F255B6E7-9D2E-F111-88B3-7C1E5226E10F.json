                  "item/ks_antwort_erwartet": false,
                  "item/ks_antwort_sp_id": "@outputs('Move_file')?['body/ItemId']",
                  "item/ks_antwort_sp_pfad": "@outputs('Move_file')?['body/Path']",
                  "item/ks_dokumententyp": "124080013",
                  "item/ks_dokumententyp_text": "Divers",
                  "item/ks_LookUpAuftrage@odata.bind": "/ks_auftrages(@{items('For_each')?['ks_auftrageid']})",
