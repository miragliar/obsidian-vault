        "List_rows_-_Auftrag": {
          "type": "OpenApiConnection",
          "inputs": {
            "parameters": {
              "entityName": "ks_auftrages",
              "$filter": "_ks_lookupsubunternehmer_value eq '@{outputs('Get_a_row_by_ID_-_Subunternehmer')?['body/crb4b_subunternehmerid']}' and ks_status_auftrag eq 'Offen'"
            },
            "host": {
              "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps",
              "operationId": "ListRecords",
              "connectionName": "shared_commondataserviceforapps-1"
            }
          },
          "runAfter": {
            "Get_a_row_by_ID_-_Subunternehmer": [
              "Succeeded"
