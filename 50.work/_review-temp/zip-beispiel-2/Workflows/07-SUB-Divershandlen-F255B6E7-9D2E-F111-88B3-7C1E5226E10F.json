          }
        },
        "For_each": {
          "type": "Foreach",
          "foreach": "@outputs('List_rows_-_Auftrag')?['body/value']",
          "actions": {
            "Move_file": {
              "type": "OpenApiConnection",
              "inputs": {
                "parameters": {
                  "dataset": "@parameters('SP_SiteURL (ks_SP_SiteURL)')",
                  "parameters/sourceFileId": "@triggerBody()?['text_2']",
                  "parameters/destinationDataset": "@parameters('SP_SiteURL (ks_SP_SiteURL)')",
