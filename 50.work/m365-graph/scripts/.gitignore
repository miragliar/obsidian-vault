# =====================================================================
# Token-Cache & Secrets — NIEMALS committen
# Regel (Giovanni 2026-06-09): Tokens IMMER verschlüsselt im OS-Keystore
# (macOS Keychain / Windows DPAPI), nie als Klartext-.bin im Vault/Dropbox.
# Diese Patterns sind die Defense-in-Depth-Schicht: falls doch mal eine
# .bin-Datei entsteht (alter Skript-Stand, Migration), darf sie wenigstens
# nicht ins Git/GitHub. Vor jedem Commit `git status` + Diff prüfen.
# =====================================================================
*.bin
.token_cache*
.pbi_token_cache_*
# (Glob .token_cache* deckt auch .token_cache.bin, .token_cache.bin.legacy ab.)

# Output-JSONs enthalten echte Mail- & Chat-Inhalte — Privatsphäre
mail_digest.json
teams_digest.json
mail_summaries*.json
teams_summaries*.json
firmenprofile.json
batch_export.log
ppweekly_digest.json
ppweekly_analysis.json
ppweekly_releases.json

# Python venv
.venv/
__pycache__/
*.pyc

# Environment variables (falls als .env gespeichert)
.env
.env.local

# v2-Staging und alte Backups
_staging-v2/
*.v1.*.bak
